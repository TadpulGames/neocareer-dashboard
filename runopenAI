    const allowedOrigins = allowedOriginsStr.split(",").map(s => s.trim()).filter(Boolean);
    
    // Explicitly check if origin is allowed
    if (origin && allowedOrigins.includes(origin)) {
      res.set("Access-Control-Allow-Origin", origin);
      res.set("Access-Control-Allow-Methods", "POST, OPTIONS");
      res.set("Access-Control-Allow-Headers", "Content-Type, Authorization");
      res.set("Access-Control-Allow-Credentials", "true");
    }
    
    // Handle preflight OPTIONS request
    if (req.method === "OPTIONS") {
      return res.status(204).send("");
    }

      try {
      const authHeader = req.headers.authorization;
      if (!authHeader || !authHeader.startsWith("Bearer ")) {
        return sendError(res, origin, 401, "Authentication required");
      }

      let userId;
      try {
        const idToken = authHeader.split("Bearer ")[1];
        const decodedToken = await admin.auth().verifyIdToken(idToken);
        userId = decodedToken.uid;
      } catch (e) {
        logger.warn("Invalid auth token", e);
        return sendError(res, origin, 401, "Authentication failed");
      }
    // Rate limiting
    const xff = req.headers['x-forwarded-for'];
    const clientIP = (xff ? xff.split(',')[0].trim() : req.ip) || 'unknown';
    const now = Date.now();

    if (!rateLimitMap.has(clientIP)) rateLimitMap.set(clientIP, []);
    const attempts = rateLimitMap.get(clientIP);
    const recentAttempts = attempts.filter(time => now - time < 60 * 1000); // 1 min window

    if (recentAttempts.length >= MAX_ATTEMPTS_PER_MINUTE) {
      logger.warn("Rate limit exceeded", { clientIP });
      return res.status(429).json({ error: "Too many requests. Please wait a minute." });
    }

    recentAttempts.push(now);
    rateLimitMap.set(clientIP, recentAttempts);

    // Occasionally clean up old entries
    if (Math.random() < 0.1) cleanupRateLimit();

      const smtpKey = SMTP_KEY.value();
      if (!smtpKey) throw new Error("SMTP_KEY not defined");

      const { to, subject, body, templateId, templateData, sender, cc } = req.body;
