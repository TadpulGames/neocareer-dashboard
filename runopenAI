export const e2eCandidateLogin = onRequest(
  { region: "us-central1" },
  async (req, res) => {

    // --- CORS ---
    const origin = req.headers.origin;
    const allowedOriginsStr =
      process.env.ALLOWED_ORIGINS ||
      "http://localhost:3000,http://localhost:3001,https://candidate-neorecruit.web.app";

    const allowedOrigins = allowedOriginsStr
      .split(",")
      .map(o => o.trim());

    if (origin && allowedOrigins.includes(origin)) {
      res.set("Access-Control-Allow-Origin", origin);
      res.set(
        "Access-Control-Allow-Headers",
        "Content-Type, Authorization, x-e2e-test"
      );
      res.set("Access-Control-Allow-Methods", "POST, OPTIONS");
      res.set("Access-Control-Allow-Credentials", "true");
    }

    // ✅ Preflight
    if (req.method === "OPTIONS") {
      return res.status(204).send("");
    }

    // 🔐 Hard E2E guard
    if (req.headers["x-e2e-test"] !== "true") {
      return res.status(403).json({ error: "Forbidden" });
    }

    // 🔑 Create Firebase custom token
    const customToken = await admin.auth().createCustomToken(
      "e2e-candidate-uid",
      {
        email: "e2e-candidate@neorecruit.com",
        role: "candidate",
        e2e: true
      }
    );

    return res.status(200).json({ customToken });
  }
);
