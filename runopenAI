// Helper function to determine status from events
function determineStatus(events) {
  if (events.some(e => e.event === 'hard-bounced')) return 'Hard Bounced';
  if (events.some(e => e.event === 'spam')) return 'Marked as Spam';
  if (events.some(e => e.event === 'rejected')) return 'Rejected';
  if (events.some(e => e.event === 'soft-bounced')) return 'Soft Bounced';
  if (events.some(e => e.event === 'unsubscribed')) return 'Unsubscribed';
  if (events.some(e => e.event === 'clicked')) return 'Clicked';
  if (events.some(e => e.event === 'opened')) return 'Opened';
  if (events.some(e => e.event === 'delivered')) return 'Delivered';
  if (events.some(e => e.event === 'processed')) return 'Processed';
  return 'Sent';
}


