/**
 * Get or create Firestore client for requested databaseId (safe).
 * Falls back to admin.firestore() for default if desired.
 */
function getFirestoreForDB(databaseId) {
  const dbId = databaseId || "default";

  if (!ALLOWED_DATABASES.has(dbId)) {
    throw new Error(`Invalid databaseId: ${dbId}`);
  }

  // 👉 Use admin.firestore() for default DB
  if (dbId === "default") {
    return admin.firestore();
  }

  // 👉 Use Firestore() constructor only for secondary DBs
  if (firestoreCache.has(dbId)) return firestoreCache.get(dbId);

  const client = new Firestore({
    projectId: process.env.GCLOUD_PROJECT,
    databaseId: dbId,
  });

  firestoreCache.set(dbId, client);
  return client;
}


/** 🔹 Helper: Check if link is expired */
function isLinkExpired(expiryTimestamp) {
  if (!expiryTimestamp) return false;
  const now = new Date();
  const expiry = new Date(expiryTimestamp);
  logger.info(`⏰ Checking expiry - Now: ${now.toISOString()}, Expiry: ${expiry.toISOString()}`);
  return now > expiry;
}

