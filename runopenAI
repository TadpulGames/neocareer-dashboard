          content: `You must reply ONLY in ${extraParams.userLanguage}. 
Always greet and answer in ${extraParams.userLanguage}. 
Never use English unless ${extraParams.userLanguage} is English.`
        });
      }

      if (extraParams) {
        if (extraParams.response_format) chatBody.response_format = extraParams.response_format;
        if (extraParams.functions) chatBody.functions = extraParams.functions;
        if (extraParams.function_call) chatBody.function_call = extraParams.function_call;
        if (extraParams.temperature) chatBody.temperature = extraParams.temperature;
      }

      // 🚨 AUTO-FIX for LLM-usage check (IMPORTANT)
// If a function_call is expected but frontend did not add response_format,
// force JSON output so OpenAI cannot reply in paragraphs.
if (extraParams?.function_call && !extraParams?.response_format) {
  chatBody.response_format = { type: "json_object" };
  chatBody.temperature = 0.0; // improves structured JSON reliability
}



      const r = await fetch("https://api.openai.com/v1/chat/completions", {
        method: "POST",
        headers: { Authorization: `Bearer ${apiKey}`, "Content-Type": "application/json" },
        body: JSON.stringify(chatBody),
      });

      const d = await r.json();
      if (!r.ok) {
        return res.status(500).json({ error: d.error?.message || "OpenAI chat error" });
      }

      const msg = d.choices?.[0]?.message || {};
      const reply = msg.content || msg.function_call?.arguments || "";

      return res.status(200).json({
        result: { data: { reply, raw: d } },
      });

    } catch (err) {
      return res.status(500).json({ error: err.message });
    }
  }
);




