// Helper: cleanup old rate limit entries
function cleanupRateLimit() {
  const now = Date.now();
  const oneHour = 60 * 60 * 1000;

  for (const [ip, attempts] of rateLimitMap.entries()) {
    const recent = attempts.filter(time => now - time < oneHour);
    if (recent.length === 0) {
      rateLimitMap.delete(ip);
    } else {
      rateLimitMap.set(ip, recent);
    }
  }
  logger.info('Rate limit cleanup completed', { activeKeys: rateLimitMap.size });
}

// Helper to always include CORS headers
function sendError(res, origin, status, message) {
  if (allowedOrigins.includes(origin)) {
    res.set("Access-Control-Allow-Origin", origin);
    res.set("Access-Control-Allow-Methods", "POST, OPTIONS");
    res.set("Access-Control-Allow-Headers", "Content-Type, Authorization");
  }
  return res.status(status).json({ error: message });
}

